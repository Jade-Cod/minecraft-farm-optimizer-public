# Copy to .env (gitignored). docker compose reads this automatically.
TZ=America/Los_Angeles

# ntfy phone push (optional). Keep NTFY_TOPIC secret if you enable it.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=
NTFY_ENABLED=0

# URL used as the notification tap-through link.
APP_URL=https://yourdomain.com

# Discord OAuth2 — create an app at https://discord.com/developers/applications
# Scopes needed: identify
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://yourdomain.com/auth/discord/callback

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=

# Comma-separated list of origins allowed by CORS (no trailing slash)
ALLOWED_ORIGINS=https://yourdomain.com
